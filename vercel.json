{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/affiliate/:bookie/:tipId",
      "destination": "/api/affiliate/:bookie/:tipId"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/worker/daily-signals/run",
      "schedule": "0 7 * * *"
    }
  ]
}
