{
  "name": "bamsignal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/generate-sitemap.mjs && node scripts/sync-cache-version.mjs && tsc && vite build",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:seo-manifest": "node scripts/generate-seo-manifest.mjs",
    "seo:validate": "node scripts/generate-seo-manifest.mjs && node scripts/validate-seo-content.mjs && node scripts/validate-nigeria-seo.mjs",
    "generate:brand": "node scripts/generate-brand-assets.mjs",
    "generate:email-icons": "node scripts/generate-email-social-icons.mjs",
    "preview:emails": "node scripts/preview-email-templates.mjs",
    "generate:android-icons": "node scripts/generate-android-icons.mjs",
    "android:release": "node scripts/build-android-release.mjs",
    "android:verify-assets": "node scripts/verify-android-assets.mjs",
    "generate:store-assets": "node scripts/generate-store-assets.mjs",
    "convert:showcase": "node scripts/convert-showcase-images.mjs",
    "verify:database": "node scripts/verify-database.mjs",
    "bootstrap:admin": "node scripts/bootstrap-admin.mjs",
    "test:photo-verification": "node scripts/test-photo-verification.mjs",
    "test:photo-safety": "node scripts/test-photo-safety.mjs",
    "test:interested-in-defaults": "node scripts/test-interested-in-defaults.mjs",
    "test:photo-upload-payload": "node scripts/test-photo-upload-payload.mjs",
    "test:server-import": "node scripts/smoke-server-import.mjs",
    "test:member-data-auth": "node scripts/test-member-data-auth.mjs",
    "test:diagnostics-access": "node scripts/test-diagnostics-access.mjs",
    "test:photo-upload-attribution": "node scripts/test-photo-upload-attribution.mjs",
    "test:open-app-onboarding": "node scripts/test-open-app-onboarding.mjs",
    "test:admin-action-pin-throttle": "node scripts/test-admin-action-pin-throttle.mjs",
    "test:source-integrity": "node scripts/source-integrity-check.mjs && node scripts/test-payment-catalog.mjs && node scripts/test-payment-persistence.mjs && node scripts/test-payment-webhook.mjs && node scripts/test-photo-moderation-authority.mjs && node scripts/test-profile-patch-races.mjs && node scripts/test-readiness-health.mjs && node scripts/test-auth-throttle-outage.mjs && node scripts/test-identity-exposure.mjs",
    "test:all-integrity": "npm run test:source-integrity && npm run test:server-import",
    "test:docker-integrity-stages": "node scripts/test-docker-integrity-stages.mjs",
    "prepare": "node scripts/install-githooks.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/production.js",
    "server": "node server/production.js",
    "dev:server": "node --watch server/production.js",
    "cap:sync": "npm run build && cap sync",
    "ios": "npm run cap:sync && cap open ios",
    "android": "npm run cap:sync && cap open android"
  },
  "dependencies": {
    "@capacitor-community/fcm": "^7.1.3",
    "@capacitor/android": "^7.6.7",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.6.7",
    "@capacitor/ios": "^7.6.7",
    "@capacitor/push-notifications": "^7.0.6",
    "@supabase/supabase-js": "^2.108.2",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "heic2any": "^0.0.4",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.468.0",
    "node-cron": "^4.4.1",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^6.0.2",
    "telegraf": "^4.16.3",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.7",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.51.0",
    "sharp": "^0.35.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.21"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
