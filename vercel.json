{
  "_comment": "LEGACY — production deploys via Coolify/Docker only. See DEPLOYMENT.md.",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/webhooks/paystack",
      "destination": "/api/webhooks/paystack"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
