# BamSignal — staging profile (local staging / pre-production)
# Copy to .env.local OR merge: cp .env.staging .env.local && fill secrets
# Validate: ENV_TARGET=staging npm run validate:environment -- --connectivity
# Certifications: CERTIFICATION_EXECUTION_MODE=staging npm run certify:database

NODE_ENV=development
PORT=39457
HOST=0.0.0.0
PUBLIC_APP_URL=https://staging.bamsignal.com
VITE_PUBLIC_APP_URL=https://staging.bamsignal.com

# --- [MANDATORY] Database / Supabase ---
DATABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- [MANDATORY] Authentication (admin / command center) ---
COMMAND_CENTER_PIN=
COMMAND_CENTER_EMAILS=
CRON_SECRET=

# --- [MANDATORY] Payments ---
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=https://staging.bamsignal.com/payment/success
PAYSTACK_ANDROID_CALLBACK_URL=com.bamsignal.com://payment-success
PAYSTACK_WEBHOOK_URL=https://staging.bamsignal.com/api/paystack/webhook

# --- [MANDATORY] Email ---
RESEND_API_KEY=
SIGNUP_EMAIL_FROM=BamSignal <support@bamsignal.com>
SUPPORT_EMAIL_FROM=BamSignal <support@bamsignal.com>

# --- [RECOMMENDED] WhatsApp (Sendchamp) ---
SENDCHAMP_API_KEY=
SENDCHAMP_SENDER=
SENDCHAMP_WHATSAPP_SENDER=
SENDCHAMP_BASE_URL=https://api.sendchamp.com/api/v1

# --- [RECOMMENDED] Signal Concierge meetings ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://staging.bamsignal.com/api/calendar?action=oauth-callback
GOOGLE_CALENDAR_REFRESH_TOKEN=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
GOOGLE_MEET_CLIENT_ID=
GOOGLE_MEET_CLIENT_SECRET=
GOOGLE_MEET_REFRESH_TOKEN=

# --- [OPTIONAL] Firebase push ---
FIREBASE_SERVICE_ACCOUNT_JSON=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- [OPTIONAL] OpenAI (AI workspace — not on critical path) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Certification ---
CERTIFICATION_EXECUTION_MODE=staging
ENV_TARGET=staging
CERTIFICATION_BASE_URL=http://127.0.0.1:39457
DIAGNOSTICS_SECRET=
RUN_MIGRATIONS_ON_STARTUP=true
