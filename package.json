{
  "name": "bamsignal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/generate-sitemap.mjs && tsc && vite build",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:brand": "node scripts/generate-brand-assets.mjs",
    "generate:showcase": "node scripts/convert-showcase-images.mjs",
    "convert:showcase": "node scripts/convert-showcase-images.mjs",
    "verify:database": "node scripts/verify-database.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/production.js",
    "server": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "cap:sync": "npm run build && cap sync",
    "ios": "npm run cap:sync && cap open ios",
    "android": "npm run cap:sync && cap open android"
  },
  "dependencies": {
    "@capacitor-community/fcm": "^7.1.3",
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/push-notifications": "^7.0.6",
    "@supabase/supabase-js": "^2.105.1",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.468.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.35.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
