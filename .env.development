# BamSignal — local development profile
# Copy to .env.local and fill values. DATABASE_URL optional (server runs in dry-run without it).
# Validate: ENV_TARGET=development npm run validate:environment

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- Mandatory for client dev (buildtime) ---
# [MANDATORY] Supabase project URL for Vite client
VITE_SUPABASE_URL=
# [MANDATORY] Supabase anon key for Vite client
VITE_SUPABASE_ANON_KEY=
# [MANDATORY] Public site URL for client links
VITE_PUBLIC_APP_URL=http://localhost:5173

# --- Recommended for full local member flows ---
# [RECOMMENDED] Postgres — without this, DATABASE_URL absent → dry-run mode
DATABASE_URL=
# [RECOMMENDED] Server Supabase URL (defaults to VITE_SUPABASE_URL)
SUPABASE_URL=
# [RECOMMENDED] Service role for signup email + photo storage
SUPABASE_SERVICE_ROLE_KEY=
# [RECOMMENDED] Paystack test secret for payment flows
PAYSTACK_SECRET_KEY=
# [RECOMMENDED] Paystack test public key (client)
VITE_PAYSTACK_PUBLIC_KEY=
# [RECOMMENDED] Resend for signup/contact email
RESEND_API_KEY=

# --- Optional integrations (warn only if missing) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
SENDCHAMP_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
GOOGLE_MEET_CLIENT_ID=
GOOGLE_MEET_CLIENT_SECRET=
OPENAI_API_KEY=
TELEGRAM_ENABLE_POLLING=false

# Certification local overrides
# CERTIFICATION_EXECUTION_MODE=dry-run
# ENV_TARGET=development
