# BamSignal production — Coolify / Docker

# --- Deployment metadata (optional — surfaced on /health and /ready) ---
# APP_ENV=production
# DEPLOY_PLATFORM=coolify
# DEPLOY_PROVIDER=hetzner
# APP_VERSION=0.1.0
# GIT_COMMIT_SHA=...          (Coolify may inject COOLIFY_SOURCE_COMMIT)
# BUILD_TIME=2026-07-21T12:00:00.000Z
# NODE_ENV=production
# LOG_LEVEL=info

# =============================================================================
# DOCKER BUILD (Coolify: Available at Buildtime = ON)
# Public client-side vars only — never put secrets here.
# =============================================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_PUBLIC_APP_URL=https://bamsignal.com
VITE_SUPPORT_EMAIL=support@bamsignal.com
# Paystack PUBLIC key only (pk_test_… or pk_live_…). Never put sk_ secret here.
VITE_PAYSTACK_PUBLIC_KEY=
# Alias supported for portability (same value as VITE_PAYSTACK_PUBLIC_KEY):
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_PUBLIC_KEY=
# Referral invite widget on member home (default off until campaign launch)
VITE_ENABLE_REFERRALS_UI=false
# Photo moderation — upload-first: upload all valid images; flag suspicious for admin review
VITE_ENABLE_IMAGE_MODERATION=true
VITE_PHOTO_MODERATION_MODE=upload_first

# Server photo moderation (upload_first | review | strict)
PHOTO_MODERATION_MODE=upload_first

# =============================================================================
# CONTAINER RUNTIME (Coolify: Available at Runtime = ON, Buildtime = OFF)
# Backend reads these from process.env when the container starts.
# =============================================================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
PUBLIC_APP_URL=https://bamsignal.com

# --- Supabase / database ---
# Postgres connection string (Render internal URL on Render; external URL for local verify)
DATABASE_URL=
# Service role key — required for signup email verification (server creates confirmed users)
# and profile/cover photo uploads to Supabase Storage (profile-photos, cover-photos buckets).
SUPABASE_SERVICE_ROLE_KEY=
# Server-side Supabase project URL (runtime). Falls back to VITE_SUPABASE_URL if unset.
SUPABASE_URL=
# Anon key for verifying member JWTs on photo upload API (falls back to VITE_SUPABASE_ANON_KEY).
SUPABASE_ANON_KEY=
# Legacy alias — prefer SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=
# Set PGSSLMODE=disable only for local Postgres without TLS
# PGSSLMODE=disable
# Apply migrations/ on container boot (Coolify). Set false if you run npm run migrate externally.
RUN_MIGRATIONS_ON_STARTUP=true

# --- Paystack ---
PAYSTACK_SECRET_KEY=
# Optional dedicated webhook signing secret (falls back to PAYSTACK_SECRET_KEY):
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=https://bamsignal.com/payment/success
PAYSTACK_ANDROID_CALLBACK_URL=com.bamsignal.com://payment-success
PAYSTACK_WEBHOOK_URL=https://bamsignal.com/api/paystack/webhook

# --- Google Calendar (Signal Concierge) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://bamsignal.com/api/calendar?action=oauth-callback
# Server-side event creation after OAuth connect:
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# --- Zoom (Signal Concierge meetings) ---
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# --- Google Meet (Signal Concierge meetings) ---
GOOGLE_MEET_CLIENT_ID=
GOOGLE_MEET_CLIENT_SECRET=
GOOGLE_MEET_REFRESH_TOKEN=
GOOGLE_MEET_CALENDAR_ID=primary

# --- Email (contact form) ---
RESEND_API_KEY=
SUPPORT_EMAIL_FROM=BamSignal <support@bamsignal.com>
CONCIERGE_EMAIL_FROM=BamSignal Signal Concierge <support@bamsignal.com>
SIGNUP_EMAIL_FROM=BamSignal <support@bamsignal.com>
SUPPORT_EMAIL_TO=support@bamsignal.com

# --- Command Center ---
# Comma-separated emails allowed for console login (legacy: ADMIN_EMAILS)
COMMAND_CENTER_EMAILS=ops@bamsignal.com
# 4-digit PIN required for destructive/save actions in the console (legacy: ADMIN_ACTION_PIN)
COMMAND_CENTER_PIN=
# First-time console access: open https://bamsignal.com/hard/auth when no operator exists yet.
ADMIN_BOOTSTRAP_EMAIL=ops@bamsignal.com
ADMIN_BOOTSTRAP_PASSWORD=
# POST /api/admin/bootstrap — disabled by default; enable only during controlled setup.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_SECRET=
# GET/POST /api/hard/setup — legacy console setup; disabled by default; header x-setup-secret only.
LEGACY_SETUP_ENABLED=false
LEGACY_SETUP_SECRET=
CRON_SECRET=
# Dedicated admin automation secret (header x-bamsignal-secret). Required in production — do not reuse CRON_SECRET.
ADMIN_SECRET=
# Optional: separate secret for /api/diagnostics/* and /ready?details=1 (header x-diagnostics-secret only)
DIAGNOSTICS_SECRET=
# Production E2E Certification™ — test emails must use this domain (e.g. runid-a@cert.bamsignal.com)
CERTIFICATION_EMAIL_DOMAIN=cert.bamsignal.com
# Certification runner target (default https://bamsignal.com)
# CERTIFICATION_BASE_URL=https://bamsignal.com
# Optional: admin consent HMAC — falls back to ADMIN_SECRET
ADMIN_CONSENT_SECRET=

# --- Sendchamp (SMS Verification + concierge WhatsApp templates) ---
SENDCHAMP_API_KEY=
# SMS sender ID shown on OTP (production: YIKE)
SENDCHAMP_SENDER=YIKE
SMS_SENDER_ID=YIKE
SMS_PROVIDER=sendchamp
SENDCHAMP_WHATSAPP_SENDER=
SENDCHAMP_BASE_URL=https://api.sendchamp.com/api/v1
# Product verification policy
SMS_VERIFICATION_REQUIRED_FOR_MESSAGING=true
SELFIE_VERIFICATION_REQUIRED_FOR_MESSAGING=true
EMAIL_VERIFICATION_REQUIRED=true
DEFAULT_COUNTRY=NG
DEFAULT_PHONE_REGION=NG
SUPPORTED_COUNTRIES=NG
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=30
OTP_MAX_ATTEMPTS=5
OTP_RESEND_SECONDS=60
# --- National face verification (provider-based; never call InsightFace from app code) ---
# insightface | facenet | noop
FACE_VERIFICATION_PROVIDER=insightface
# Optional remote ML service implementing /detect /embed /verify
FACE_VERIFICATION_ENDPOINT=
FACE_VERIFICATION_API_KEY=
FACENET_VERIFICATION_ENDPOINT=
FACENET_VERIFICATION_API_KEY=
INSIGHTFACE_MODEL_VERSION=insightface-buffalo_l
FACENET_MODEL_VERSION=facenet-v1
FACE_VERIFICATION_TIMEOUT_MS=15000
# Trust thresholds (0–100)
FACE_MATCH_AUTO_VERIFY_MIN=95
FACE_MATCH_MANUAL_REVIEW_MIN=80
# When true, messaging requires national face-match unlock (default false preserves F&F SMS+selfie submit)
FACE_MATCH_REQUIRED_FOR_MESSAGING=false
# Client mirror (Vite build)
# VITE_FACE_MATCH_REQUIRED_FOR_MESSAGING=false
# AES key material for encrypted verification metadata (falls back to ADMIN_SECRET)
VERIFICATION_METADATA_KEY=
SENDCHAMP_WHATSAPP_TEMPLATE_CONSULTATION_REMINDER=
SENDCHAMP_WHATSAPP_TEMPLATE_MEETING_STARTING_SOON=
SENDCHAMP_WHATSAPP_TEMPLATE_INTRODUCTION_ACCEPTED=
SENDCHAMP_WHATSAPP_TEMPLATE_FOLLOW_UP_REMINDER=
SENDCHAMP_WHATSAPP_TEMPLATE_MILESTONE_CONGRATULATIONS=
# Delivery webhook (Sendchamp dashboard): https://bamsignal.com/api/verify/whatsapp/webhook
# SMS OTP API: POST /api/verify/sms/start | /api/verify/sms/confirm

# --- Optional ---
APP_TIMEZONE=Africa/Lagos
TELEGRAM_BOT_TOKEN=
TELEGRAM_FREE_CHANNEL_ID=
TELEGRAM_VIP_GROUP_ID=
TELEGRAM_ENABLE_POLLING=false
# Optional: Telegram identity webhook — set TELEGRAM_WEBHOOK_SECRET (do not reuse CRON_SECRET)
TELEGRAM_WEBHOOK_SECRET=
# --- Optional build-only (not required for production runtime) ---
# VITE_APP_BUILD_ID=
# VITE_STORE_SCREENSHOTS=false

# --- Firebase (optional — push notifications only; app works when false) ---
# Preferred: paste the full service account JSON as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternative discrete vars:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
