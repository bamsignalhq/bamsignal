# BamSignal production — Coolify / Docker

# --- Frontend (must be available at Docker BUILD time) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PUBLIC_APP_URL=https://bamsignal.com
VITE_SUPPORT_EMAIL=support@bamsignal.com
VITE_PAYSTACK_PUBLIC_KEY=

# --- Server runtime ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
PUBLIC_APP_URL=https://bamsignal.com

# --- Supabase / database ---
# Postgres connection string (Render internal URL on Render; external URL for local verify)
DATABASE_URL=
# Set PGSSLMODE=disable only for local Postgres without TLS
# PGSSLMODE=disable

# --- Paystack ---
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK_URL=https://bamsignal.com/payment/success
PAYSTACK_WEBHOOK_URL=https://bamsignal.com/api/paystack/webhook

# --- Email (contact form) ---
RESEND_API_KEY=
SUPPORT_EMAIL_FROM=BamSignal <support@bamsignal.com>
SUPPORT_EMAIL_TO=support@bamsignal.com

# --- Admin ---
ADMIN_EMAILS=ops@bamsignal.com
CRON_SECRET=

# --- Optional ---
APP_TIMEZONE=Africa/Lagos
TELEGRAM_BOT_TOKEN=
TELEGRAM_FREE_CHANNEL_ID=
TELEGRAM_VIP_GROUP_ID=
TELEGRAM_ENABLE_POLLING=false
FIREBASE_SERVICE_ACCOUNT_JSON=
